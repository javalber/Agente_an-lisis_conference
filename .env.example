# ============================================================================
# Copia este archivo a `.env` para el modo de prueba local (run_local.py).
# En GitHub Actions estos valores se configuran como *Secrets* (ver README).
# ============================================================================

# --- Gmail (IMAP + SMTP) ---
# Usa una APP PASSWORD de Google (no tu contraseña normal). Requiere 2FA activo.
GMAIL_USER=tucorreo@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Remitente conocido a buscar (tu correo profesional del banco) ---
# Si se deja vacío, se usa GMAIL_USER.
SENDER_EMAIL=tu.nombre@banco.com

# --- Destinatarios del correo de resumen (separados por coma) ---
RECIPIENTS=persona1@ejemplo.com, persona2@ejemplo.com

# --- Etiqueta de Gmail que marca un correo como ya procesado ---
PROCESSED_LABEL=procesado

# --- Prefijo del asunto del correo de salida ---
SUBJECT_PREFIX=Resumen conference call –

# --- Selección de qué resumir / qué reenviar ---
# Los documentos llegan duplicados EN/ES y la presentación viene como PDF.
# Roles a resumir (coma): presentation, report, excel, invitation.
SUMMARIZE_ROLES=presentation,report,excel
# Idioma a resumir: en | es  (los 'neutral', como el Excel, siempre se incluyen).
SUMMARIZE_LANGUAGE=en
# Qué adjuntar al correo de salida: all | summarized | language
FORWARD_ATTACHMENTS=all
# Tope de caracteres por documento enviado al modelo (salvaguarda coste/contexto).
MAX_CONTENT_CHARS=400000

# ============================================================================
# MODELO DE IA
# En FASE 1 dejar STUB_MODE=true: los nodos de IA devuelven resúmenes FALSOS
# y NO se contacta ninguna API. En FASE 3 se pone STUB_MODE=false y se setea
# la API key del proveedor elegido.
# ============================================================================
STUB_MODE=true

# El proveedor NO está hardcodeado: se resuelve vía init_chat_model de LangChain.
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6

# API key del proveedor (solo necesaria cuando STUB_MODE=false, en Fase 3).
# Para Anthropic:
ANTHROPIC_API_KEY=